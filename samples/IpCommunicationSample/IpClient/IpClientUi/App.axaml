<avalonia:Application x:Class="IpClientUi.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:IpClient"
             xmlns:avalonia="https://github.com/avaloniaui"
             xmlns:reactiveUi="clr-namespace:ReactiveUI;assembly=ReactiveUI"
             RequestedThemeVariant="Default">
    <avalonia:Application.DataTemplates>

    </avalonia:Application.DataTemplates>

    <avalonia:Application.Styles>
        <avalonia:FluentTheme />
        <avalonia:Style Selector="avalonia|Label.h1">
            <avalonia:Setter Property="FontSize" Value="24"/>
            <avalonia:Setter Property="FontWeight" Value="Bold"/>
        </avalonia:Style>

        <avalonia:Style Selector="avalonia|Grid.Bottom">
            <avalonia:Setter Property="Background" Value="LightGray"/>
        </avalonia:Style>
    </avalonia:Application.Styles>
</avalonia:Application>